# Anthropic API (server-side only)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server (Express API — must match Vite proxy target in client/vite.config.ts)
PORT=8080

# Database (SQLite locally by default; Postgres in production on DigitalOcean)
# Local dev default when unset: file:../../data/dev.db (relative to server/prisma/)
# DATABASE_URL=file:../../data/dev.db
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
