# Anthropic API (server-side only)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3001

# GitHub Contents API (bookmark storage — optional in local dev)
# If unset locally: uses `gh auth token` when available, otherwise saves to data/projects/ on disk
# PAT needs contents: read/write on the repository when using GitHub storage
# GITHUB_TOKEN=ghp_your-token-here
# Optional locally — defaults to `git remote get-url origin` (owner/repo)
# GITHUB_REPO=owner/repo
# BOOKMARK_STORAGE=github|local  # force backend (auto-detected in dev)
GITHUB_DATA_PATH=data/projects
