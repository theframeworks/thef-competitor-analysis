# Anthropic API (server-side only)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server (Express API — must match Vite proxy target in client/vite.config.ts)
PORT=8080

# PostgreSQL (production bookmark storage)
# DigitalOcean injects this when you link a managed Postgres database to the app.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Bookmark storage backend (auto-detected if unset)
# postgres — when DATABASE_URL is set, or in production
# local    — JSON files under data/projects/ (default local dev)
# github   — commit JSON to the repo via GitHub Contents API
# BOOKMARK_STORAGE=local

# GitHub Contents API (optional — legacy bookmark storage for local dev)
# GITHUB_TOKEN=ghp_your-token-here
# GITHUB_REPO=owner/repo
# GITHUB_DATA_PATH=data/projects
