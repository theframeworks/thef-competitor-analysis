generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String   @id
  name          String
  anchorName    String   @map("anchor_name")
  brands        Json
  opportunities Json
  crossThemes   Json?    @map("cross_themes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([updatedAt])
  @@map("projects")
}
